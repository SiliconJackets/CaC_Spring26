TOPLEVEL=syn_dll

TSMC_STD_CELL=$(PDKS)/tsmc/N65LP/digital/Front_End/verilog/tcbn65lp_200a/tcbn65lp_pwr.v

SRC=./syn_dll.apr.v \
	./delay_cell.sv \
	./tb.v \
	$(TSMC_STD_CELL)

.DEFAULT_GOAL := vcs

$(TOPLEVEL).include:Makefile
	echo $(SRC) > $(TOPLEVEL).include

vcs:$(TOPLEVEL).include 
	vcs -f $(TOPLEVEL).include +v2k +optconfigfile+$(TOPLEVEL).cfg -R +lint=all -sverilog -full64 \
		-timescale=1ns/10ps -debug_acc+pp+dmptf -debug_region+cell+encrypt \
		-debug_access +neg_tchk -l $(TOPLEVEL).log +define+POST_APR=1 \
		+define+SAPR +define+SIM=1 +define+POWER_PINS +define+INITIALIZE_MEMORY +define+ARM_UD_MODEL

clean_hex:
	make -C $(PRJ)/src/firmware clean	

clean:
	rm -rf $(TOPLEVEL).include
	rm -rf alib-52
	rm -rf db
	rm -rf ddc
	rm -rf $(TOPLEVEL)
	rm -rf reports
	rm -rf netlist
	rm -rf csrc
	rm -rf simv.daidir
	rm -rf DVEfiles
	rm -rf *.log
	rm -rf vcdplus.vpd
	rm -rf ucli.key
	rm -rf default.svf
	rm -rf simv

