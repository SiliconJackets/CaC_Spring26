TOPLEVEL=neuro_soc
PRJ=/gscratch/psylab/usr/kpatinos/riscv_dsp
TSMC_STD_CELL=$(PDKS)/tsmc/N65LP/digital/Front_End/verilog/tcbn65lp_200a/tcbn65lp_pwr.v \
			  $(PDKS)/tsmc/N65LP/digital/Front_End/verilog/tcbn65lplvt_200a/tcbn65lplvt_pwr.v \
			  $(PDKS)/tsmc/N65LP/digital/Front_End/verilog/tphn65lpgv2od3_sl_140a/tphn65lpgv2od3_sl.v



CPU_SRC=cpu_domain.apr.v
ACC_SRC=acc_domain.apr.v
MEM_SRC=mem_domain.apr.v
TEST_SRC=test_domain.apr.v \
		 test_mem_domain.apr.v

LVL_SRC=./mem2acc_in_pinplacement.apr.v \
		./cpu2acc_in_pinplacement.apr.v \
		./cpu2acc_out_pinplacement.apr.v \
		./mem2acc_out_pinplacement.apr.v \
		./mem2cpu_in_pinplacement.apr.v \
		./mem2cpu_out_pinplacement.apr.v \
		./test2cpu_in_pinplacement.apr.v \
		./LVLLH_CUSTOM_LP_pwr.v

PAD_CELL=/gscratch/psylab/common/pad_ip/pad_pdb3a_g_fdthru.v

SRC=./neuro_soc.apr.v \
	./neuro_soc_tb.sv \
	$(CPU_SRC) \
	$(ACC_SRC) \
	$(MEM_SRC) \
	$(TEST_SRC) \
	$(LVL_SRC) \
	$(TSMC_STD_CELL) \
	$(PAD_CELL) \
	./global_constants.svh \
	-v ./tsdn65lpa2048x32m8f_200b_tt1p2v25c.v \
	-v ./tsdn65lpa128x16m4f_200b_tt1p2v25c.v \
	-v ./ro_ip_with_converter_lp.sv \
	-v ./delay_chain_100ps_top.sv


.DEFAULT_GOAL := vcs

link_src:
	ln -s -f $(PRJ)/src/soc/neuro_soc_mock.sv .
	ln -s -f $(PRJ)/src/soc/neuro_soc_tb.sv .
	ln -s -f $(PRJ)/src/soc/include/global_constants.svh .
	find $(PRJ)/apr -name '*.apr.v' -exec ln -s -f {} ';'
	find $(PRJ)/apr -name '*.sdf' -exec ln -s -f {} ';'
	find $(PRJ)/macros -name '*.apr.v' -exec ln -s -f {} ';'
	rm *no_pg*

main.hex:$(PRJ)/src/firmware/main.c
	make -C $(PRJ)/src/firmware
	ln -s $(PRJ)/src/firmware/main.hex 

adc_sample.mem:$(PRJ)/src/python/sample_data.py
	make -C $(PRJ)/src/python
	ln -s $(PRJ)/src/python/adc_sample.mem

$(TOPLEVEL).include:Makefile
	echo $(SRC) > $(TOPLEVEL).include

vcs:$(TOPLEVEL).include main.hex adc_sample.mem
	vcs -f $(TOPLEVEL).include +v2k -R +lint=all -sverilog -full64 \
		-timescale=1ns/10ps -debug_acc+pp+dmptf -debug_region+cell+encrypt \
		-debug_access +neg_tchk -l $(TOPLEVEL).log \
		+define+SAPR +define+TOP_APR +define+POWER_PINS +define+INITIALIZE_MEMORY +define+ARM_UD_MODEL

clean_hex:
	make -C $(PRJ)/src/firmware clean	

clean:
	rm -rf $(TOPLEVEL).include
	rm -rf alib-52
	rm -rf db
	rm -rf ddc
	rm -rf $(TOPLEVEL)
	rm -rf reports
	rm -rf netlist
	rm -rf csrc
	rm -rf simv.daidir
	rm -rf DVEfiles
	rm -rf *.log
	rm -rf vcdplus.vpd
	rm -rf ucli.key
	rm -rf default.svf
	rm -rf simv

