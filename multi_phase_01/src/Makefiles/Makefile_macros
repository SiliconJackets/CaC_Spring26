MW_EXEC=Milkyway
LC_EXEC=lc_shell

# TCL scripts
TCL_LC=convert_lib.tcl
TCL_MW=create_fram.tcl

# Directories
LOGDIR=./results
RESULTDIR=./results 
REPORTDIR=./reports
MACRODIR=../src/macro_prep

# MW library
MACRO_LIB=./trng_macro_lib
.PHONY: all clean create_lib create_fram create_qtm dc

convert_lib:
	$(LC_EXEC) -64bit -f $(TCL_LC) | tee lc_shell.log

create_fram:
	-$(MW_EXEC) -nullDisplay -f $(TCL_MW) | tee create_reg_fram.log
	-@ rm -rf Milkyway.*

create_qtm:
	if [ ! -d $(REPORTDIR) ]; then mkdir $(REPORTDIR); fi
	if [ ! -d $(RESULTDIR) ]; then mkdir $(RESULTDIR); fi
	-pt_shell -f ${MACRO_NAME}.tcl | tee $(REPORTDIR)/${MACRO_NAME}.log
	-sed -i 's/dont_use : true/dont_use : false/g' ${MACRO_NAME}.lib

create_db:
	-create_qtm
	-convert_lib

clean:
	-@ rm -rf $(MACRO_LIB) \
			  $(LOGDIR) \
			  $(RESULTDIR) \
			  $(REPORTDIR) \
			  *.lib \
			  *defineVarRoute* \
			  *.db \
			  *.svf \
			  *.log \
			  Milkyway.* \
			  rf alib-52 \
			  rf WORK
